# Copy to .env and fill in. All keys are OPTIONAL.
# Without an OpenAI key the app runs in deterministic offline (rule-based) mode.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_EMBED_MODEL=text-embedding-3-small

# OKF memory for the Contract Risk Agent
OKF_MEMORY_ROOT=backend/agent_profiles/contract_agent_profile
BID_RECOMMENDER_AGENT_OKF_MEMORY_ROOT=backend/agent_profiles/bid_recommender_agent_profile
OKF_WRITE_MEMORY_INDEX=1
OKF_INDEX_PGVECTOR=1
OKF_USE_PGVECTOR_RETRIEVAL=1

# Decision history memory for the Contract Risk Agent
DECISION_HISTORY_MEMORY_ENABLED=1
DECISION_HISTORY_GLOBAL_LIMIT=10
DECISION_HISTORY_VENDOR_LIMIT=5
DECISION_HISTORY_CATEGORY_LIMIT=5
DECISION_HISTORY_SIMILAR_LIMIT=5
DECISION_HISTORY_ITEM_CHAR_LIMIT=500
DECISION_HISTORY_TOTAL_CHAR_LIMIT=6000

# Postgres
# Docker compose backend -> Docker db
DATABASE_URL=postgresql://premortem:premortem@db:5432/premortem
# Local backend -> Docker db exposed on host port 5433
# DATABASE_URL=postgresql://premortem:premortem@127.0.0.1:5433/premortem
# Local backend -> local Postgres on host port 5432
# DATABASE_URL=postgresql://premortem:premortem@127.0.0.1:5432/premortem

# Frontend -> backend URL
PREMORTEM_API=http://localhost:8000
